# Central environment variable template for deployments

# Backend (Spring Boot / Render)
# Provide a JDBC URL (example format for Supabase Postgres):
# jdbc:postgresql://db.<region>.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://<HOST>:<PORT>/<DBNAME>
SPRING_DATASOURCE_USERNAME=<DB_USER>
SPRING_DATASOURCE_PASSWORD=<DB_PASSWORD>

# Optional alternative name some platforms provide (Heroku-style)
JDBC_DATABASE_URL=

# CORS: allow the frontend origin (set to your Vercel URL)
APP_CORS_ORIGINS=https://your-frontend.vercel.app

# Frontend (Vite / Vercel)
# Vite requires env vars starting with VITE_ to be embedded at build time
VITE_API_BASE=https://your-backend.onrender.com

# Supabase client (if used by frontend)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Other useful values
# APP_ENV=production# Docker Compose Environment Variables Template
# Copy this file to .env for local development and production
# Make sure to update with secure values for production

# PostgreSQL credentials (used by both db and backend services)
POSTGRES_PASSWORD=your-secure-db-password-here

# Backend database connection (optional overrides)
SPRING_DATASOURCE_USERNAME=eventfinder
SPRING_DATASOURCE_PASSWORD=your-secure-db-password-here
