# Docker Compose Environment Variables Template
# Copy this file to .env for local development and production
# Make sure to update with secure values for production

# PostgreSQL credentials (used by both db and backend services)
POSTGRES_PASSWORD=your-secure-db-password-here

# Backend database connection (optional overrides)
SPRING_DATASOURCE_USERNAME=eventfinder
SPRING_DATASOURCE_PASSWORD=your-secure-db-password-here
